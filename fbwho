def is_rtl(text):
    return bool(re.search(r'[\u0600-\u06FF\u0750-\u077F\u08A0-\u08FF\uFB50-\uFDFF\uFE70-\uFEFF]', text))


def wrap_rtl(text):
    if text and is_rtl(text):
        return f'\u202b{text}\u202c'
    return text


def extract_display_name(html, username):
    patterns = [
        r'<meta[^>]+property="og:title"[^>]+content="([^"]+)"',
        r'<meta[^>]+property="article:author"[^>]+content="([^"]+)"',
        r'"actorName":"([^"]+)"',
        r'"ownerName":"([^"]+)"',
        r'"displayName":"([^"]+)"',
        r'"nameForDisplay":"([^"]+)"',
        r'"userName":"([^"]+)"',
    ]

    results = []
    for p in patterns:
        for m in re.finditer(p, html, re.IGNORECASE):
            results.append(m.group(1))

    BAD_NAMES = frozenset({'error', 'facebook', 'connection_quality', 'latency_level', 'is_ad', 'is_live', 'fbls_tier', 'content_category', 'streaming_implementation', 'is_latency_sensitive_broadcast'})

    for name in results:
        cleaned = re.sub(r'\s+', ' ', decode_unicode_escapes(name)).strip()
        if cleaned and cleaned.lower() not in BAD_NAMES and 'Facebook' not in cleaned and len(cleaned) > 1 and len(cleaned) < 100:
            return cleaned

    return None


def extract_from_json_ld(html):
    m = re.search(r'<script[^>]+type="application/ld\+json"[^>]*>(.*?)</script>', html, re.DOTALL)
    if not m:
        return None
    try:
        data = json.loads(m.group(1))
        if isinstance(data, list):
            data = data[0]
        if isinstance(data, dict):
            author = data.get('author') or data.get('publisher') or {}
            if isinstance(author, dict):
                return author.get('name')
    except (json.JSONDecodeError, AttributeError):
        pass
    return None


def extract_poster_name(html, username, group_id=None):
    name = extract_from_json_ld(html)
    if name:
        return name

    name = extract_display_name(html, username)
    if name:
        return name

    soup = None
    try:
        from bs4 import BeautifulSoup
        soup = BeautifulSoup(html, 'html.parser')
    except ImportError:
        return None

    if soup:
        for tag in soup.find_all('meta'):
            if tag.get('property') in ('og:title', 'article:author') or tag.get('name') in ('author', 'twitter:title'):
                c = tag.get('content', '')
                if c and 'Facebook' not in c:
                    return re.sub(r'\s+', ' ', c).strip()

        for tag in soup.find_all('a'):
            href = tag.get('href', '')
            if username and username.lower() in href.lower() and tag.text.strip():
                txt = tag.text.strip()
                if txt and len(txt) < 80:
                    return txt

    return None


