def extract_user_activity(html, group_id, user_id=None):
    posts = []
    comments = []
    seen_posts = set()
    seen_comments = set()

    # Find post permalinks
    gid = re.escape(group_id)
    for m in re.finditer(r'href="(/groups/' + gid + r'/permalink/(\d+)[^"]*)"', html):
        post_id = m.group(2)
        if post_id not in seen_posts:
            seen_posts.add(post_id)
            posts.append(f"https://www.facebook.com/groups/{group_id}/permalink/{post_id}/")

    # Find story URLs from React props
    for m in re.finditer(r'"storyURL":"([^"]+)"', html):
        url = m.group(1).replace('\\/', '/')
        pid = extract_post_id(url)
        if pid and pid not in seen_posts:
            seen_posts.add(pid)
            if url not in posts:
                posts.append(url)

    # Find actor posts via story data
    if user_id:
        for m in re.finditer(r'"actorID":"?' + re.escape(user_id) + r'"?', html):
            for s in re.finditer(r'"storyID":"(\d+)"', html[max(0, m.start()-2000):m.end()+2000]):
                sid = s.group(1)
                if sid not in seen_posts:
                    seen_posts.add(sid)
                    posts.append(f"https://www.facebook.com/groups/{group_id}/permalink/{sid}/")

    # Find comments by this user
    if user_id:
        for m in re.finditer(r'"authorID":"?' + re.escape(user_id) + r'"?', html):
            for c in re.finditer(r'"commentID":"(\d+)"', html[max(0, m.start()-2000):m.end()+2000]):
                cid = c.group(1)
                if cid not in seen_comments:
                    seen_comments.add(cid)
                    body_m = re.search(r'"body":{"text":"([^"]+)"', html[c.start():c.end()+2000])
                    text = body_m.group(1) if body_m else ''
                    comments.append((cid, text))

    return posts[:15], comments[:10]


def lookup_username(name, token, cookies):
    if token:
        gu = retry_request(f'https://graph.facebook.com/v19.0/{name}', params={
            'fields': 'id,name,link',
            'access_token': token,
        }, timeout=8, retries=2)
        if gu and gu.status_code == 200:
            ud = gu.json()
            return ud.get('name'), ud.get('id')
    found_name = None
    found_uid = None
    for url in [
        f"https://www.facebook.com/{name}",
        f"https://mbasic.facebook.com/{name}",
    ]:
        resp = retry_request(url, headers={'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}, cookies=cookies, timeout=6, retries=1)
        if not resp:
            continue
        body = resp.text
        uid_m = re.search(r'"userID":"(\d+)"', body)
        if uid_m and not found_uid:
            found_uid = uid_m.group(1)
        og = re.search(r'<meta[^>]+property="og:title"[^>]+content="([^"]+)"', body)
        if og:
            t = html.unescape(og.group(1))
            if t and 'Facebook' not in t and len(t) < 80:
                found_name = found_name or t
                break
        title_m = re.search(r'<title[^>]*>(.*?)</title>', body, re.DOTALL)
        if title_m:
            t = html.unescape(re.sub(r'\s+', ' ', title_m.group(1)).strip())
            if t and 'Facebook' not in t and len(t) < 80:
                found_name = found_name or t
    return found_name, found_uid or name


def lookup_user(user_id, token, cookies):
    if token:
        gu = retry_request(f'https://graph.facebook.com/v19.0/{user_id}', params={
            'fields': 'name,id,link',
            'access_token': token,
        }, timeout=8, retries=2)
        if gu and gu.status_code == 200:
            ud = gu.json()
            return ud.get('name'), ud.get('id')

    name = None
    for url in [
        f"https://www.facebook.com/profile.php?id={user_id}",
        f"https://www.facebook.com/{user_id}",
        f"https://mbasic.facebook.com/profile.php?id={user_id}",
    ]:
        resp = retry_request(url, headers={'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}, cookies=cookies, timeout=6, retries=1)
