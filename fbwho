def load_cookies(path):
    if not path or not os.path.exists(path):
        return None
    try:
        with open(path) as f:
            data = json.load(f)
        if isinstance(data, dict) and 'data' in data:
            print(f"  {YLW}   ↳ Encrypted cookie file — re-export as JSON{RST}")
            return None
        jar = requests.cookies.RequestsCookieJar()
        if isinstance(data, list):
            for c in data:
                name = c.get('name') or c.get('key') or ''
                value = c.get('value') or ''
                domain = c.get('domain', '').lstrip('.')
                path_c = c.get('path', '/')
                secure = c.get('secure', False)
                if name and value and domain:
                    jar.set(name, value, domain=domain, path=path_c, secure=secure)
            return jar
    except (json.JSONDecodeError, UnicodeDecodeError):
        pass
    try:
        jar = requests.cookies.RequestsCookieJar()
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith('#') or line.startswith('#'):
                    continue
                parts = line.split('\t')
                if len(parts) >= 7:
                    domain, _, path_c, secure, _, name, value = parts[:7]
                    jar.set(name, value, domain=domain.lstrip('.'), path=path_c, secure=(secure.upper() == 'TRUE'))
        return jar
    except Exception:
        return None


