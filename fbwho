def extract_post_id(url):
    patterns = [
        r'/posts/([^/?]+)',
        r'/videos/([^/?]+)',
        r'/reel/([^/?]+)',
        r'/stories/([^/?]+)',
        r'fbid=(\d+)',
        r'story_fbid=(\d+)',
        r'photo\.php\?.*fbid=(\d+)',
        r'/photo/?\?fbid=(\d+)',
        r'/photos/[^/]+/(\d+)',
        r'permalink\.php\?story_fbid=(\d+)',
        r'/permalink/(\d+)',
        r'/groups/\d+/posts/(\d+)',
    ]
    for p in patterns:
        m = re.search(p, url)
        if m:
            return m.group(1)
    return None


EXCLUDED = frozenset({'posts', 'videos', 'reel', 'stories', 'photo', 'photo.php', 'photos', 'permalink.php', 'story.php', 'watch', 'share', 'hashtag', 'groups', 'events', 'notes', 'pages', 'login', 'signup', 'me', 'messages', 'notifications', 'settings', 'friends', 'marketplace', 'watch', 'gaming'})

def extract_username(url):
    u = urlparse(url)
    parts = [p for p in u.path.split('/') if p]
    if parts:
        first = parts[0].lower()
        if first not in EXCLUDED:
            return parts[0]
    m = re.findall(r'facebook\.com/([a-zA-Z0-9._-]+)', url)
    for name in m:
        if name.lower() not in EXCLUDED:
            return name
    return None


def extract_group_id(url):
    m = re.search(r'/groups/(\d+)', url)
    return m.group(1) if m else None


def decode_unicode_escapes(s):
    return re.sub(r'\\u([0-9a-fA-F]{4})', lambda m: chr(int(m.group(1), 16)), s)


def rgb_to_xterm(r, g, b):
    best = 0
    best_dist = 1e9
    for ci in range(16, 256):
        if ci < 232:
            idx = ci - 16
            cr = (idx // 36) * 51
            cg = ((idx // 6) % 6) * 51
            cb = (idx % 6) * 51
        else:
            level = (ci - 232) * 10 + 8
            cr = cg = cb = level
        dr = r - cr
        dg = g - cg
        db = b - cb
        dist = dr * dr + dg * dg + db * db
        if dist < best_dist:
            best_dist = dist
            best = ci
    return best


def render_pic(url, width=24, circular=True):
    try:
        from PIL import Image
        import io
        resp = retry_request(url, timeout=5, retries=1)
        if not resp:
            return None
        img = Image.open(io.BytesIO(resp.content))
        if img.mode != 'RGB':
            img = img.convert('RGB')
        aspect = img.height / img.width
        h = max(int(width * aspect * 0.5), 4)
        img = img.resize((width, h * 2), Image.LANCZOS)
        pixels = list(img.getdata())
        cx, cy = width / 2, h
        radius = min(cx, h)
        lines = []
        for y in range(h):
            row = ''
            for x in range(width):
                t = y * 2
                if circular:
                    dx1, dy1 = x + 0.5 - cx, (t + 0.5) - cy
                    dx2, dy2 = x + 0.5 - cx, (t + 1.5) - cy
                    in1 = dx1*dx1 + dy1*dy1 <= radius*radius
                    in2 = dx2*dx2 + dy2*dy2 <= radius*radius
                    if not in1 and not in2:
                        row += '\033[0m '
                        continue
                    if not in1:
                        r2, g2, b2 = pixels[(t + 1) * width + x]
                        c2 = rgb_to_xterm(r2, g2, b2)
                        row += f'\033[38;5;{c2};48;5;{c2}m\u2584'
                        continue
                    if not in2:
                        r1, g1, b1 = pixels[t * width + x]
                        c1 = rgb_to_xterm(r1, g1, b1)
                        row += f'\033[38;5;{c1};48;5;{c1}m\u2580'
                        continue
                r1, g1, b1 = pixels[t * width + x]
                r2, g2, b2 = pixels[(t + 1) * width + x]
                c1 = rgb_to_xterm(r1, g1, b1)
                c2 = rgb_to_xterm(r2, g2, b2)
                row += f'\033[38;5;{c1};48;5;{c2}m\u2584'
            lines.append(row + '\033[0m')
        return lines
    except Exception as e:
        return None


def print_pic(url):
    lines = render_pic(url, width=24, circular=True)
    if lines:
        try:
            cols = os.get_terminal_size().columns
        except OSError:
            cols = 80
        for line in lines:
            pad = max(0, (cols - 24) // 2)
