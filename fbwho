def playwright_fetch(url, cookies_path=None, wait=6):
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        return None
    if not os.path.exists(PW_CHROME):
        return None
    jar = load_cookies(cookies_path) if cookies_path else None
    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(
                headless=True,
                executable_path=PW_CHROME,
                args=['--headless=new', '--no-sandbox', '--disable-gpu', '--disable-dev-shm-usage']
            )
            ctx = browser.new_context(
                user_agent='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
                viewport={'width': 1280, 'height': 720},
            )
            if jar:
                pw_cookies = []
                for c in jar:
                    pw_cookies.append({
                        'name': c.name,
                        'value': c.value,
                        'domain': c.domain,
                        'path': c.path or '/',
                        'httpOnly': False,
                        'secure': c.secure or False,
                        'sameSite': 'Lax',
                    })
                ctx.add_cookies(pw_cookies)
            page = ctx.new_page()
            page.goto(url, timeout=20000, wait_until='domcontentloaded')
            page.wait_for_timeout(wait * 1000)
            result = page.evaluate('''() => {
                const r = {};
                r.profile_pic = '';
                const svgImages = document.querySelectorAll('svg image');
                for (const img of svgImages) {
                    const href = img.getAttribute('xlink:href') || img.getAttribute('href') || '';
                    if (href.includes('fbcdn') && href.includes('.jpg')) {
                        r.profile_pic = href;
                        break;
                    }
                }
                if (!r.profile_pic) {
                    const all = document.querySelectorAll('img');
                    const candidates = [];
                    for (const img of all) {
                        const src = img.src || '';
                        if (src.includes('fbcdn') && src.includes('.jpg') && !src.includes('emoji')) {
                            const w = img.naturalWidth || img.width || 0;
                            if (w >= 80 && w <= 300) candidates.push({ src, w });
                        }
                    }
                    candidates.sort((a, b) => b.w - a.w);
                    if (candidates.length) r.profile_pic = candidates[0].src;
                }
                const title = document.querySelector('title');
                r.title = title ? title.innerText : '';
                const timeEls = document.querySelectorAll('[data-utime], time, [data-tooltip-content]');
                r.timestamps = [];
                for (const el of timeEls) {
                    const utime = el.getAttribute('data-utime');
                    if (utime) r.timestamps.push(utime);
                }
                return r;
            }''')
            browser.close()
            return result
    except Exception as e:
        return None


