    patterns = [
        r'"username":"([^"]+)"',
        r'"userName":"([^"]+)"',
        r'/([a-zA-Z0-9._]+)/posts/' + re.escape(post_id),
        r'profile\.php\?id=(\d+)',
    ]
    for p in patterns:
        m = re.search(p, html)
        if m:
            return m.group(1)
    return None


def parse_post_id_from_input(raw):
    if raw.startswith('http://') or raw.startswith('https://'):
        return raw, None
    if raw.startswith('fb.com/'):
        return f"https://{raw}", None
    if '/' in raw or '.' in raw:
        if not raw.startswith('http'):
            return f"https://{raw}", None
        return raw, None

    return None, raw


