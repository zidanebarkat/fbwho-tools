            continue
        html = resp.text
        title_m = re.search(r'<title[^>]*>(.*?)</title>', html, re.DOTALL)
        if title_m:
            t = re.sub(r'\s+', ' ', title_m.group(1)).strip()
            if t and 'Facebook' not in t and len(t) < 80:
                name = re.sub(r'\s*\|.*$', '', t).strip()
                break
        extracted = extract_poster_name(html, None)
        if extracted and 'Facebook' not in extracted and len(extracted) < 80:
            name = extracted
            break
        og = re.search(r'<meta[^>]+property="og:title"[^>]+content="([^"]+)"', html)
        if og:
            ot = og.group(1)
            if ot and 'Facebook' not in ot and len(ot) < 80:
                name = ot
                break

    if not name or name == 'Unknown':
        import tempfile
        if cookies:
            tmpf = tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False)
            export = [{'name': c.name, 'value': c.value, 'domain': c.domain,
                        'path': c.path or '/', 'secure': c.secure, 'httpOnly': False}
                      for c in cookies]
            json.dump(export, tmpf)
            tmpf.close()
            pw = playwright_fetch(f'https://www.facebook.com/profile.php?id={user_id}', cookies_path=tmpf.name, wait=4)
            os.unlink(tmpf.name)
        else:
            pw = playwright_fetch(f'https://www.facebook.com/profile.php?id={user_id}', wait=4)
        if pw and pw.get('title'):
            t = re.sub(r'\s*\|.*$', '', pw.get('title', '')).strip()
            if t and 'Facebook' not in t and len(t) < 80:
                name = t

    return name, None


def check_group_membership(group_id, target, cookies):
    uid = target if target.isdigit() else None
    uname = None if target.isdigit() else target
    if not uid:
        _, uid = lookup_username(target, None, cookies)
    if not uid:
        return None, 'could not resolve target to a user ID'
    url = f"https://www.facebook.com/groups/{group_id}/user/{uid}/"
    resp = retry_request(url, headers={'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}, cookies=cookies, timeout=6, retries=1)
    if not resp:
        return None, 'could not fetch group user page'
    title_m = re.search(r'<title[^>]*>(.*?)</title>', resp.text, re.DOTALL)
    if not title_m:
        return None, 'no title found'
    t = html.unescape(re.sub(r'\s+', ' ', title_m.group(1)).strip())
    if t and t != 'Facebook' and 'Error' not in t and len(t) < 80:
        return (uid, t), None
    return None, 'user not found in group'


